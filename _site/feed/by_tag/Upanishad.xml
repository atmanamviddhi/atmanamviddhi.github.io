    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;तिष्ठति&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;He stands&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;संसृज्य&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;projecting&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;गोपाः&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;protector&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;सम्चुकोच&lt;/td&gt;
