      &lt;td style=&quot;text-align: center&quot;&gt;हि&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;indeed&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;द्वितीयाय&lt;/td&gt;
