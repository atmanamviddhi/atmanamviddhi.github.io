    &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;अतमः&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;absence of darkness&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;तत्&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;then&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
