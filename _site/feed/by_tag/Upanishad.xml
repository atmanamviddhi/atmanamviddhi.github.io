    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;यथा एव&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;just as&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;मृदया&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;by dust&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
