    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;सुधान्तम् (सत्)&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;when cleaned&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;तेजोमयम्&lt;/td&gt;
