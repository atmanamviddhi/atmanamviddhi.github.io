    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;वीतशोकः&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;free from sorrow&lt;/td&gt;
    &lt;/tr&gt;
