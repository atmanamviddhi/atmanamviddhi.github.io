    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;भ्राजते&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;shines&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;तद् वा&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;in like manner&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;देही&lt;/td&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;the embodied being&lt;/td&gt;
    &lt;/tr&gt;
    &lt;tr&gt;
      &lt;td style=&quot;text-align: center&quot;&gt;प्रसमीक्ष्य&lt;/td&gt;
